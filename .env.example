APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=replace-me
JIRA_PROJECT_KEY=SUPPORT
JIRA_POLL_INTERVAL_SECONDS=300
JIRA_LOOKBACK_MINUTES=30

DATABASE_URL=postgresql+psycopg://support_ai:support_ai@localhost:5432/support_ai

LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:14b-instruct
LLM_TIMEOUT_SECONDS=120
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=

ENABLE_JIRA_COMMENT_PUBLISH=false
ENABLE_SCHEDULER=false
